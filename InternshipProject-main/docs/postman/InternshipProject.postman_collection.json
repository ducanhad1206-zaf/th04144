{
  "info": {
    "name": "Internship Project API",
    "description": "Full Postman collection updated to match internth04144 SQL schema (roles: ADMIN/EMPLOYEE, assigneeId)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.test('Code is 201', function () { pm.expect(json.code).to.eql(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{managerUsername}}\",\n  \"email\": \"{{managerEmail}}\",\n  \"password\": \"{{managerPassword}}\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('userId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userUsername}}\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"role\": \"EMPLOYEE\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('managerToken', json.data.token);",
                  "pm.test('Token exists', function () { pm.expect(json.data.token).to.be.a('string').and.not.empty; });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{managerUsername}}\",\n  \"password\": \"{{managerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('userToken', json.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userUsername}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Manager Flow",
      "item": [
        {
          "name": "Create Project (ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('projectId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{managerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{projectName}}\",\n  \"description\": \"{{projectDescription}}\"\n}"
            },
            "url": "{{baseUrl}}/api/projects"
          }
        },
        {
          "name": "Add Member to Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 200', function () { pm.response.to.have.status(200); });"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{managerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{userId}}\n}"  // chỉnh đúng với SQL
            },
            "url": "{{baseUrl}}/api/projects/{{projectId}}/members"
          }
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.environment.set('taskId', json.data.id);",
                  "pm.test('Default status TODO', function () { pm.expect(json.data.status).to.eql('TODO'); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{managerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{taskTitle}}\",\n  \"description\": \"{{taskDescription}}\",\n  \"projectId\": {{projectId}},\n  \"deadline\": \"{{taskDeadline}}\"\n}"
            },
            "url": "{{baseUrl}}/api/tasks"
          }
        },
        {
          "name": "Assign Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test('Assignee set', function () { pm.expect(json.data.assignee.id).to.eql(Number(pm.environment.get('userId'))); });"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{managerToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assigneeId\": {{userId}}\n}"  // chỉnh theo SQL
            },
            "url": "{{baseUrl}}/api/tasks/{{taskId}}/assign"
          }
        }
      ]
    },
    {
      "name": "User Flow",
      "item": [
        {
          "name": "List Own Tasks",
          "event": [{"listen": "test","script":{"type":"text/javascript","exec":["pm.test('Status is 200', function () { pm.response.to.have.status(200); });"]}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization","value":"Bearer {{userToken}}"}],
            "url": "{{baseUrl}}/api/tasks/by-user/{{userId}}"
          }
        },
        {
          "name": "Update Own Task Status -> IN_PROGRESS",
          "event": [{"listen": "test","script":{"type":"text/javascript","exec":["pm.test('Status is 200', function () { pm.response.to.have.status(200); });","var json = pm.response.json();","pm.test('Status updated', function () { pm.expect(json.data.status).to.eql('IN_PROGRESS'); });"]}}],
          "request": {
            "method": "PUT",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Authorization","value":"Bearer {{userToken}}"}],
            "body": {"mode":"raw","raw":"{\n  \"status\": \"IN_PROGRESS\"\n}"},
            "url": "{{baseUrl}}/api/tasks/{{taskId}}/status"
          }
        }
      ]
    }
  ],
  "variable": [
    {"key":"baseUrl","value":"http://localhost:8080"},
    {"key":"managerUsername","value":"admin_demo_01"},
    {"key":"managerEmail","value":"admin_demo_01@mail.com"},
    {"key":"managerPassword","value":"123456"},
    {"key":"userUsername","value":"emp_demo_01"},
    {"key":"userEmail","value":"emp_demo_01@mail.com"},
    {"key":"userPassword","value":"123456"},
    {"key":"projectName","value":"Project Demo Full Flow"},
    {"key":"projectDescription","value":"Created in Postman run"},
    {"key":"taskTitle","value":"Implement full API flow"},
    {"key":"taskDescription","value":"Task created and verified by collection"},
    {"key":"taskDeadline","value":"2026-12-31"},
    {"key":"managerToken","value":""},
    {"key":"userToken","value":""},
    {"key":"userId","value":""},
    {"key":"projectId","value":""},
    {"key":"taskId","value":""}
  ]
}